APP_NAME="META MINEC"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Locale/faker y zona horaria del pais destino: El Salvador (UTC-6).
# Nota: la zona horaria se fija tambien en AppServiceProvider (America/El_Salvador)
# porque no existe config/app.php; este valor es solo documental.
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_SV
APP_TIMEZONE=America/El_Salvador

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# Logs -> stderr (visibles en Dokploy UI / docker service logs)
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de datos: MySQL únicamente
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=meta_minec
DB_USERNAME=meta_minec
DB_PASSWORD=

# Sesion y cache: file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Colas: Redis, supervisadas por Horizon (cliente predis)
QUEUE_CONNECTION=redis
CACHE_STORE=file
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Correo: Mailgun
MAIL_MAILER=mailgun
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net
MAIL_FROM_ADDRESS="no-reply@minec.gob.sv"
MAIL_FROM_NAME="${APP_NAME}"

# SSO Google Workspace (Socialite)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
# Dominio de Workspace permitido (p. ej. minec.gob.sv). Vacío = cualquier cuenta Google.
GOOGLE_HOSTED_DOMAIN=

# Control de acceso (RBAC / ISO 27001 A.5.15, A.8.2). SSO solo Google por defecto.
SECURITY_SSO_ONLY=true
# Acceso local exclusivo de la cuenta Super Admin (break-glass). Poner false para
# deshabilitar por completo el login local.
SECURITY_LOCAL_ADMIN_LOGIN=true
# Correos adicionales con acceso local (correo+contraseña), además del Super Admin.
# Separados por coma. Útil para cuentas de demostración; vaciar tras la demo.
SECURITY_LOCAL_LOGIN_EMAILS=

# Cuenta local Super Admin (break-glass). Se sincroniza en cada deploy vía
# `php artisan superadmin:sync`. Definir estas variables en Dokploy; si quedan
# vacías, no se crea/actualiza la cuenta.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_NAME="Super Administrador"

# Seguridad: cabeceras HSTS y CSP (A.8.24). Dejar los valores por defecto.
# Si tras un deploy la app se ve en blanco, poner CSP_REPORT_ONLY=true para
# diagnosticar (no bloquea), o CSP_ENABLED=false como último recurso.
HSTS_ENABLED=true
CSP_ENABLED=true
CSP_REPORT_ONLY=false

# Backups (Dropbox) - A.12.3
DROPBOX_BACKUP_TOKEN=
DROPBOX_BACKUP_PATH=/backups/meta-minec

# Inteligencia Artificial (Anthropic / Claude)
# La llave se genera en console.anthropic.com -> Settings -> API Keys.
# Se puede configurar tambien desde el panel (Configuracion -> Inteligencia
# Artificial), que tiene prioridad sobre estas variables.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

VITE_APP_NAME="${APP_NAME}"
