APP_NAME="META MINEC"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Locale/faker apuntan al pais destino (El Salvador);
# la zona horaria toma la del equipo de trabajo (ahora Santo Domingo, RD).
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_SV
APP_TIMEZONE=America/Santo_Domingo

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# Logs -> stderr (visibles en Dokploy UI / docker service logs)
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de datos: MySQL únicamente
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=meta_minec
DB_USERNAME=meta_minec
DB_PASSWORD=

# Sesion y cache: file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Colas: Redis, supervisadas por Horizon (cliente predis)
QUEUE_CONNECTION=redis
CACHE_STORE=file
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Correo: Mailgun
MAIL_MAILER=mailgun
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net
MAIL_FROM_ADDRESS="no-reply@minec.gob.sv"
MAIL_FROM_NAME="${APP_NAME}"

# SSO Office 365 / Azure AD (Socialite)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI="${APP_URL}/auth/azure/callback"
AZURE_TENANT_ID=

# Backups (Dropbox) - A.12.3
DROPBOX_BACKUP_TOKEN=
DROPBOX_BACKUP_PATH=/backups/meta-minec

VITE_APP_NAME="${APP_NAME}"
